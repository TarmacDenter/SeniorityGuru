{
  "name": "seniority-guru",
  "private": true,
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:debug": "nuxt dev --debug",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:restart": "supabase stop && supabase start",
    "db:reset": "supabase db reset && npm run db:types",
    "db:types": "supabase gen types typescript --local | grep -v '^Connecting' > shared/types/database.ts",
    "db:seed-airlines": "node --env-file=.env supabase/scripts/seed-airlines.js",
    "db:seed-airlines:prod": "node --env-file=.env.prod supabase/scripts/seed-airlines.js",
    "db:seed-users": "node --env-file=.env supabase/scripts/seed-users.js",
    "db:seed-seniority": "node --env-file=.env supabase/scripts/seed-seniority.js",
    "db:seed-dev": "node --env-file=.env supabase/scripts/seed-dev.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@nuxt/ui": "^4.0.0",
    "@nuxthub/core": "latest",
    "@nuxtjs/supabase": "^2.0.4",
    "@pinia/nuxt": "^0.11.3",
    "chart.js": "^4.5.1",
    "nuxt": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "vue-chartjs": "^5.3.3",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@iconify-json/lucide": "^1.2.96",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@types/node": "^22.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.4",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "semantic-release": "^24.2.9",
    "supabase": "^2.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.0.0"
  }
}
