# =============================================================================
# Development environment variables
# Copy to .env and fill in values from `supabase start` output
# Production values are configured in the Vercel dashboard (never commit them)
# =============================================================================

# Public — safe to expose to client
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=<anon key from `supabase start`>

# Server-only — never expose to client
SUPABASE_SECRET_KEY=<service_role key from `supabase start`>
